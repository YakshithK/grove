{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SenseDesk",
  "version": "0.1.0",
  "identifier": "com.sensedesk.dev",
  "build": {
    "frontendDist": "../frontend/dist",
    "beforeDevCommand": null,
    "beforeBuildCommand": "cd frontend && npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "SenseDesk",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "dialog": null
  }
}
